{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Bootstrap venv",
			"type": "shell",
			"command": "${workspaceFolder}/scripts/bootstrap-venv.sh",
			"problemMatcher": []
		},
		{
			"label": "Validate example configs",
			"type": "shell",
			"command": "bash",
			"args": [
				"${workspaceFolder}/scripts/validate-configs.sh"
			],
			"dependsOn": "Bootstrap venv",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "Run host tests",
			"type": "shell",
			"command": "bash",
			"args": [
				"${workspaceFolder}/scripts/run-host-tests.sh"
			],
			"dependsOn": "Bootstrap venv",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "Run pre-commit hooks",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/bin/pre-commit",
			"args": [
				"run",
				"--all-files"
			],
			"dependsOn": "Bootstrap venv",
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "Run hello-world config",
			"type": "shell",
			"command": "${workspaceFolder}/scripts/esphomew",
			"args": [
				"run",
				"configs/hello-world.yaml"
			],
			"dependsOn": "Bootstrap venv",
			"group": "build",
			"problemMatcher": []
		}
	]
}
