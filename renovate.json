{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":enablePreCommit"
  ],
  "timezone": "Europe/Berlin",
  "schedule": [
    "after 6:00am and before 7:00am on monday"
  ],
  "dependencyDashboardOSVVulnerabilitySummary": "unresolved",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "rangeStrategy": "in-range-only"
  },
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Preserve the supported runtime dependency ranges validated by the ESPHome compatibility matrix",
      "matchManagers": [
        "pip_requirements"
      ],
      "matchFileNames": [
        "requirements.txt"
      ],
      "rangeStrategy": "in-range-only"
    },
    {
      "matchManagers": [
        "pip_requirements"
      ],
      "matchFileNames": [
        "requirements-dev.txt"
      ],
      "rangeStrategy": "bump"
    }
  ]
}
