{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":configMigration"
  ],
  "timezone": "Europe/Berlin",
  "schedule": [
    "after 6:00am and before 7:00am on monday"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardOSVVulnerabilitySummary": "unresolved",
  "osvVulnerabilityAlerts": true,
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "prConcurrentLimit": 5,
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group GitHub Actions updates like Dependabot did.",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions",
      "groupSlug": "github-actions"
    },
    {
      "description": "Group Python requirements updates like Dependabot did.",
      "matchManagers": [
        "pip_requirements"
      ],
      "groupName": "python-dependencies",
      "groupSlug": "python-dependencies",
      "rangeStrategy": "bump"
    },
    {
      "description": "Group pre-commit hook updates.",
      "matchManagers": [
        "pre-commit"
      ],
      "groupName": "pre-commit-hooks",
      "groupSlug": "pre-commit-hooks"
    }
  ]
}
