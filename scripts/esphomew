#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR

ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
readonly ROOT_DIR

readonly ESPHOME_BIN="${ROOT_DIR}/.venv/bin/esphome"

if [[ ! -x "${ESPHOME_BIN}" ]]; then
  cat >&2 <<'EOF'
ESPHome is not installed in the local virtual environment.
Run ./scripts/setup.sh first, then retry the ESPHome command.
EOF
  exit 1
fi

cd "${ROOT_DIR}"
exec "${ESPHOME_BIN}" "$@"
